{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echopathxr.com/schemas/ai_witness_dataset.schema.json",
  "title": "AI Witness Dataset",
  "type": "object",
  "required": [
    "schema",
    "dataset_id",
    "dataset_version",
    "protocol_version",
    "claim_level",
    "condition_label",
    "source_class",
    "privacy_mode",
    "confidence"
  ],
  "properties": {
    "schema": {
      "const": "echonet.ai_witness_dataset"
    },
    "dataset_id": {
      "type": "string"
    },
    "dataset_version": {
      "type": "string"
    },
    "protocol_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "claim_level": {
      "type": "string",
      "enum": [
        "simulation_reference",
        "research_export",
        "runtime_observation",
        "pilot_measurement",
        "sealed_research_event"
      ]
    },
    "condition_label": {
      "type": "string",
      "enum": [
        "active",
        "baseline",
        "sham",
        "decoy",
        "holdout",
        "unknown"
      ]
    },
    "source_class": {
      "type": "string",
      "enum": [
        "aethernode",
        "simulation",
        "runtime",
        "mixed"
      ]
    },
    "sensor_modalities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "node_count": {
      "type": "integer",
      "minimum": 0
    },
    "cluster_count": {
      "type": "integer",
      "minimum": 0
    },
    "coverage_window_start": {
      "type": "string"
    },
    "coverage_window_end": {
      "type": "string"
    },
    "calibration_version": {
      "type": "string"
    },
    "algorithm_version": {
      "type": "string"
    },
    "projection_mode": {
      "type": "string"
    },
    "privacy_mode": {
      "type": "string",
      "enum": [
        "public_safe",
        "internal",
        "sealed"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence_method": {
      "type": "string"
    },
    "bounded_features": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "string", "boolean", "null"]
      }
    },
    "covariates": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "string", "boolean", "null"]
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "seal_mode": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "downstream_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
